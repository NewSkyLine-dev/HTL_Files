<Window x:Class="MT.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MT"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Margin="0,0,0,10">Suchbegriff:</TextBlock>
            <TextBox Grid.Row="1" Margin="0,0,0,10" x:Name="tbSearch"/>
            <Button Grid.Row="2" Margin="0,0,0,10" Click="Button_Click">Suchen</Button>

            <ComboBox Grid.Row="3" Margin="0,0,0,10" x:Name="cbPlaces" ItemsSource="{Binding Places}" SelectionChanged="cbPlaces_SelectionChanged">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding City1}"></TextBlock>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <Button Grid.Row="4" Margin="0,0,0,10" Click="Button_Click_1">Hinzufügen</Button>

            <ListBox Grid.Row="5"
                 x:Name="lbPlaces"
                 Margin="0,0,0,10"
                 HorizontalContentAlignment="Stretch"
                 SelectionMode="Multiple"
                 SelectionChanged="lbPlaces_SelectionChanged"
                 ItemsSource="{Binding PermanentPlaces}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding City1}"></TextBlock>
                            <TextBlock Text="{Binding Lat}"></TextBlock>
                            <TextBlock Text="{Binding Lng}"></TextBlock>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <UniformGrid Grid.Row="6" Rows="1" Columns="3">
                <Button Click="Button_Click_2">Löschen</Button>
                <TextBox x:Name="tbKCluster">1</TextBox>
                <Button Click="Button_Click_3">Cluster</Button>
            </UniformGrid>
        </Grid>

        <Canvas Grid.Column="1" Width="350" Height="400" x:Name="cvMap"/>
    </Grid>
</Window>
