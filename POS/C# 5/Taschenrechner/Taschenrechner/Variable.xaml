<Window x:Class="Taschenrechner.Variable"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Taschenrechner"
        mc:Ignorable="d"
        Title="Variable" Height="150" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition></RowDefinition>
            <RowDefinition></RowDefinition>
        </Grid.RowDefinitions>

        <StackPanel>
            <Label>Gib einen Wert für die Variable ein!</Label>
            <TextBox x:Name="tbWert"></TextBox>
        </StackPanel>

        <UniformGrid Grid.Row="1">
            <Button Click="Button_Click">Ok</Button>
            <Button Click="Button_Click_1">Abbrechen</Button>
        </UniformGrid>
    </Grid>
</Window>
