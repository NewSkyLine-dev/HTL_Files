<Window x:Class="IPGraph.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ip="clr-namespace:GraphControl;assembly=GraphControl"
        xmlns:local="clr-namespace:IPGraph"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <ip:Graph x:Name="graph" StartChanged="graph_StartChanged" EndChanged="graph_StartChanged"></ip:Graph>
    </Grid>
</Window>
