<Window x:Class="Robotersteuerung.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Robotersteuerung"
        mc:Ignorable="d"
        xmlns:robot="clr-namespace:AbcRobotCore;assembly=AbcRobotCore"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="5">
            <Button Content="XML laden" Click="LoadXml_Click" Margin="5"/>
            <Button Content="Programm laden" Click="LoadProgram_Click" Margin="5"/>
            <Button Content="Ausführen" Click="Run_Click" Margin="5"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <robot:RobotField x:Name="RobotField" Grid.Column="0" Margin="5"/>

            <TextBox x:Name="CodeEditor" Grid.Column="1" 
                     FontFamily="Consolas" FontSize="13"
                     AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                     Margin="5"/>
        </Grid>

        <TextBlock x:Name="StatusBar" Grid.Row="2" 
                   Margin="5" FontSize="12" Foreground="Red" 
                   TextWrapping="Wrap"/>
    </Grid>
</Window>
